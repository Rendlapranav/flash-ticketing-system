# MongoDB connection string (needs a replica set — bookings/cancellations use transactions)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/flash-ticketing

# Upstash Redis REST credentials (used for distributed seat locks)
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your-upstash-rest-token

# Clerk secret key — verifies session tokens on checkout/bookings/admin routes
# https://dashboard.clerk.com -> API Keys -> Secret key
CLERK_SECRET_KEY=REPLACE_WITH_YOUR_CLERK_SECRET_KEY

# Comma-separated list of emails allowed to access the admin dashboard
ADMIN_EMAILS=you@example.com

# Origin allowed to call this API / connect over Socket.IO
CLIENT_ORIGIN=http://localhost:5173

PORT=5000
