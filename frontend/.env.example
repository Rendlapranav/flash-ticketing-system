# Clerk publishable key — https://dashboard.clerk.com -> API Keys -> Publishable key
VITE_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_CLERK_PUBLISHABLE_KEY

# Backend API / Socket.IO origin
VITE_BACKEND_URL=http://localhost:5000

# Comma-separated list of emails that should see the Admin nav link.
# Cosmetic only — the backend enforces access separately via its own
# ADMIN_EMAILS. Keep these two lists in sync.
VITE_ADMIN_EMAILS=you@example.com
